generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type ApplicationAiInsightsSnapshot {
  confidence      Float
  criticalGaps    ApplicationAiInsightsSnapshotCriticalGaps[]
  eligibility     ApplicationAiInsightsSnapshotEligibility
  matchScore      Int
  meta            ApplicationAiInsightsSnapshotMeta
  rankSignal      String
  rationale       String
  recommendations String[]
  scoreBreakdown  ApplicationAiInsightsSnapshotScoreBreakdown
  verdict         String
}

type ApplicationAiInsightsSnapshotCriticalGaps {
  fix    String
  gap    String
  impact String
}

type ApplicationAiInsightsSnapshotEligibility {
  isRemoteCompatible Boolean
  seniorityGap       Int
}

type ApplicationAiInsightsSnapshotMeta {
  version String
}

type ApplicationAiInsightsSnapshotScoreBreakdown {
  experience Int
  keywords   Int
  seniority  Int
  skills     Int
}

type CvJobAnalysisAnalysis {
  confidence      Float
  criticalGaps    CvJobAnalysisAnalysisCriticalGaps[]
  eligibility     CvJobAnalysisAnalysisEligibility
  matchScore      Int
  meta            CvJobAnalysisAnalysisMeta
  rankSignal      String
  rationale       String
  recommendations String[]
  scoreBreakdown  CvJobAnalysisAnalysisScoreBreakdown
  verdict         String
}

type CvJobAnalysisAnalysisCriticalGaps {
  fix    String
  gap    String
  impact String
}

type CvJobAnalysisAnalysisEligibility {
  isRemoteCompatible Boolean
  seniorityGap       Int
}

type CvJobAnalysisAnalysisMeta {
  version String
}

type CvJobAnalysisAnalysisScoreBreakdown {
  experience Int
  keywords   Int
  seniority  Int
  skills     Int
}

type CvVersionFormatIssues {
  message  String
  severity String
  type     String
}

type CvVersionProfile {
  education     CvVersionProfileEducation[]
  experience    CvVersionProfileExperience[]
  /// Could not determine type: the field only had null or empty values in the sample set.
  projects      Json?
  skills        String[]
  skillsSection CvVersionProfileSkillsSection?
  summary       String
}

type CvVersionProfileEducation {
  degree      String
  institution String
  year        String
}

type CvVersionProfileExperience {
  bullets  String[]
  company  String
  duration String?
  priority String?
  role     String
}

type CvVersionProfileSkillsSection {
  Soft_Skills       String[] @map("Soft Skills")
  Technical_Skills  String[] @map("Technical Skills")
  Tools___Platforms String[] @map("Tools & Platforms")
}

type JobStructuredData {
  companyDNA            String
  idealCandidatePersona JobStructuredDataIdealCandidatePersona
  keywords              JobStructuredDataKeywords
  meta                  JobStructuredDataMeta
  painPoints            JobStructuredDataPainPoints
  parsed                JobStructuredDataParsed
  requirements          JobStructuredDataRequirements
}

type JobStructuredDataIdealCandidatePersona {
  description String
  type        String
}

type JobStructuredDataKeywords {
  atsCritical       String[]
  recruiterTriggers String[]
}

type JobStructuredDataMeta {
  version String
}

type JobStructuredDataPainPoints {
  primaryChallenge  String
  softSkillPriority String
}

type JobStructuredDataParsed {
  function        String
  level           String
  normalizedTitle String
}

type JobStructuredDataRequirements {
  mandatory JobStructuredDataRequirementsMandatory
  preferred JobStructuredDataRequirementsPreferred
}

type JobStructuredDataRequirementsMandatory {
  experience String
  skills     String[]
}

type JobStructuredDataRequirementsPreferred {
  /// Could not determine type: the field only had null or empty values in the sample set.
  certifications Json?
  skills         String[]
}

model Account {
  id                String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  provider          Json?
  /// Field referred in an index, but found no data to define the type.
  providerAccountId Json?
  /// Field referred in an index, but found no data to define the type.
  userId            Json?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Application {
  id                 String                        @id @default(auto()) @map("_id") @db.ObjectId
  aiInsightsSnapshot ApplicationAiInsightsSnapshot
  analysisVersion    BigInt
  createdAt          DateTime                      @db.Date
  cvVersionId        String                        @db.ObjectId
  jobId              String                        @db.ObjectId
  matchScore         Float
  status             String
  /// Could not determine type: the field only had null or empty values in the sample set.
  templateId         Json?
  updatedAt          DateTime                      @db.Date
  userId             String                        @db.ObjectId

  @@index([userId, createdAt])
  @@index([jobId])
  @@index([cvVersionId])
  @@index([userId, status])
}

model CVJobAnalysis {
  id              String                @id @default(auto()) @map("_id") @db.ObjectId
  analysis        CvJobAnalysisAnalysis
  analysisVersion BigInt
  applicationId   String?               @unique @db.ObjectId
  createdAt       DateTime              @db.Date
  cvVersionId     String                @db.ObjectId
  jobId           String                @db.ObjectId
  matchScore      Float
  rankSignal      String
  userId          String                @db.ObjectId
  verdict         String

  @@unique([cvVersionId, jobId])
  @@index([userId, matchScore])
  @@index([jobId])
  @@index([rankSignal])
}

model CVVersion {
  id                   String                  @id @default(auto()) @map("_id") @db.ObjectId
  analysisVersion      BigInt
  atsContentScore      BigInt
  atsFormatScore       BigInt
  contentHash          String?
  createdAt            DateTime                @db.Date
  fileHash             String?                 @unique
  formatIssues         CvVersionFormatIssues[]
  generatedFileUrl     String?
  generatedPublicId    String?
  impactScore          BigInt?
  keywordCoverage      BigInt?
  lastAnalyzedAt       DateTime?               @db.Date
  /// Could not determine type: the field only had null or empty values in the sample set.
  localFilePath        Json?
  name                 String?
  originalFileUrl      String
  originalPublicId     String
  parentId             String?                 @db.ObjectId
  parserUsed           String?
  parsingConfidence    BigInt?
  profile              CvVersionProfile
  source               String
  /// Field referred in an index, but found no data to define the type.
  templateId           Json?
  uploadedToCloudinary Boolean
  userId               String                  @db.ObjectId

  @@index([userId, createdAt])
  @@index([templateId])
  @@index([parentId])
  @@index([atsFormatScore])
  @@index([parsingConfidence])
}

model EmailLog {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  messageId Json?  @unique
  /// Field referred in an index, but found no data to define the type.
  recipient Json?
  /// Field referred in an index, but found no data to define the type.
  status    Json?
  /// Field referred in an index, but found no data to define the type.
  type      Json?

  @@index([recipient])
  @@index([status])
  @@index([type])
}

model Job {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  analysisStatus  String
  analysisVersion BigInt
  analyzedAt      DateTime          @db.Date
  company         String
  contentHash     String            @unique
  createdAt       DateTime          @db.Date
  function        String
  level           String
  normalizedTitle String
  rawContent      String
  structuredData  JobStructuredData
  title           String
  updatedAt       DateTime          @db.Date
  userId          String            @db.ObjectId

  @@index([userId, createdAt])
  @@index([normalizedTitle])
  @@index([analysisStatus])
}

model PasswordHistory {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  userId Json?

  @@index([userId])
}

model StatusLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  applicationId String   @db.ObjectId
  changedAt     DateTime @db.Date
  status        String

  @@index([applicationId, changedAt])
}

model Template {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  createdAt Json?
  /// Field referred in an index, but found no data to define the type.
  isDefault Json?
  /// Field referred in an index, but found no data to define the type.
  userId    Json?

  @@index([userId, createdAt])
  @@index([userId, isDefault])
}

model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  /// Field referred in an index, but found no data to define the type.
  activationToken Json?    @unique
  createdAt       DateTime @db.Date
  email           String   @unique
  firstName       String
  isActive        Boolean
  isPasswordSet   Boolean
  lastName        String
  name            String
  password        String
  /// Field referred in an index, but found no data to define the type.
  resetToken      Json?    @unique
  role            String
  updatedAt       DateTime @db.Date

  @@index([isActive])
}
